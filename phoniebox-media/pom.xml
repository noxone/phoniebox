<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>eu.noxone.phoniebox</groupId>
        <artifactId>phoniebox-parent</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>phoniebox-media</artifactId>
    <name>Phoniebox :: Media</name>

    <dependencies>
        <!-- Shared domain primitives -->
        <dependency>
            <groupId>eu.noxone.phoniebox</groupId>
            <artifactId>phoniebox-shared</artifactId>
        </dependency>

        <!-- Annotation processor — generates JPA converters at compile time; not included in the JAR -->
        <dependency>
            <groupId>eu.noxone.phoniebox</groupId>
            <artifactId>phoniebox-processor</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- CDI (dependency injection) -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-arc</artifactId>
        </dependency>

        <!-- REST layer -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest-jackson</artifactId>
        </dependency>

        <!-- Persistence layer -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-hibernate-orm-panache</artifactId>
        </dependency>

        <!-- Bean validation -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-hibernate-validator</artifactId>
        </dependency>

        <!-- ──────────── Test dependencies ──────────── -->
        <dependency>
            <groupId>eu.noxone.phoniebox</groupId>
            <artifactId>phoniebox-arch</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.tngtech.archunit</groupId>
            <artifactId>archunit-junit5</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-junit5</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
